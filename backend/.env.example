# LLM Config (Select: gemini, openai, or groq)
LLM_PROVIDER=groq
# Embedding Config (Select: gemini, openai, or huggingface)
EMBEDDING_PROVIDER=huggingface

# Groq Credentials (Get free key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face Credentials (Get free token at huggingface.co/settings/tokens)
HF_API_KEY=your_hf_api_key_here

# Google Gemini Credentials (Optional)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI Credentials (Optional)
OPENAI_API_KEY=your_openai_api_key_here

# Cohere API Credentials for Reranking (Optional)
COHERE_API_KEY=your_cohere_api_key_here

# Data Storage Directory (absolute or relative path)
DATA_DIR=../data

# Environment Setting
ENV=development
PORT=8000
HOST=0.0.0.0
